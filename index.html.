<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>광공해 자가진단 - 회전 천구 모델</title>
  <style>
    :root {
      --bg1: #07111f;
      --bg2: #0f2240;
      --panel: rgba(9, 18, 34, 0.84);
      --panel2: rgba(255, 255, 255, 0.08);
      --text: #eef5ff;
      --muted: #b8c7df;
      --accent: #86b6ff;
      --accent2: #ffd166;
      --good: #74e3a3;
      --warn: #ffb86c;
      --bad: #ff7f7f;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Noto Sans KR", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 20% 15%, rgba(69, 115, 196, 0.25), transparent 18%),
        radial-gradient(circle at 80% 12%, rgba(255, 214, 102, 0.12), transparent 18%),
        linear-gradient(180deg, #020611 0%, #08111d 50%, #101d34 100%);
      min-height: 100vh;
    }
    .wrap {
      width: min(1240px, calc(100% - 20px));
      margin: 16px auto 24px;
      display: grid;
      gap: 14px;
    }
    .hero, .panel {
      background: var(--panel);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 20px;
      box-shadow: 0 18px 40px rgba(0,0,0,0.35);
      backdrop-filter: blur(8px);
    }
    .hero { padding: 18px; }
    h1 { margin: 0 0 8px; font-size: clamp(1.35rem, 2.8vw, 2rem); }
    h2 { margin: 0 0 8px; font-size: 1.1rem; }
    .sub, .small { color: var(--muted); line-height: 1.6; }
    .sub { margin: 0; }
    .layout {
      display: grid;
      grid-template-columns: 1.65fr 1fr;
      gap: 14px;
    }
    .panel { padding: 14px; }
    .sky-box { position: relative; overflow: hidden; }
    #skyCanvas {
      width: 100%;
      aspect-ratio: 16 / 10;
      display: block;
      border-radius: 18px;
      background: radial-gradient(circle at 50% 38%, #132a53 0%, #0b1730 38%, #050b15 100%);
      cursor: crosshair;
      border: 1px solid rgba(255,255,255,0.08);
    }
    .sky-overlay {
      position: absolute;
      left: 26px;
      right: 26px;
      bottom: 168px;
      display: flex;
      justify-content: space-between;
      color: rgba(255,255,255,0.72);
      font-size: 0.88rem;
      pointer-events: none;
    }
    .controls { display: grid; gap: 12px; margin-top: 12px; }
    .button-row, .input-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    button, input, select {
      appearance: none;
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.06);
      color: var(--text);
      padding: 10px 12px;
      border-radius: 12px;
      font-size: 0.95rem;
    }
    button {
      border-radius: 999px;
      cursor: pointer;
      transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
    }
    button:hover {
      transform: translateY(-1px);
      background: rgba(255,255,255,0.1);
      border-color: rgba(255,255,255,0.18);
    }
    button.active {
      background: linear-gradient(135deg, rgba(134,182,255,0.35), rgba(255,209,102,0.18));
      border-color: rgba(134,182,255,0.55);
      box-shadow: 0 0 0 1px rgba(134,182,255,0.15) inset;
    }
    input[type="number"] { width: 110px; }
    input[type="datetime-local"] { min-width: 210px; }
    .card {
      background: var(--panel2);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 14px;
      margin-top: 12px;
    }
    .label {
      display: inline-block;
      font-size: 0.82rem;
      color: #d8e6ff;
      background: rgba(134,182,255,0.14);
      border: 1px solid rgba(134,182,255,0.25);
      padding: 5px 10px;
      border-radius: 999px;
      margin-bottom: 10px;
    }
    .selected-name {
      font-size: 1.2rem;
      font-weight: 700;
      margin: 0 0 8px;
    }
    .kv, .form-grid { display: grid; gap: 8px; margin-top: 10px; }
    .kv div, .pill, .result-box {
      background: rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 10px 12px;
      font-size: 0.95rem;
      line-height: 1.5;
    }
    .tip {
      border-left: 4px solid var(--accent2);
      padding-left: 10px;
      color: #ffefb9;
      margin-top: 12px;
      font-size: 0.93rem;
      line-height: 1.6;
    }
    .list { display: grid; gap: 8px; margin-top: 10px; max-height: 280px; overflow: auto; }
    .list-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      background: rgba(255,255,255,0.05);
      border-radius: 12px;
      font-size: 0.92rem;
      cursor: pointer;
    }
    .list-item:hover { background: rgba(255,255,255,0.08); }
    .dot {
      width: 10px; height: 10px; border-radius: 50%; background: var(--accent2);
      box-shadow: 0 0 12px rgba(255,209,102,0.8); flex: 0 0 auto;
    }
    .status-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }
    .mono { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
    .good { color: var(--good); }
    .warn { color: var(--warn); }
    .bad { color: var(--bad); }
    .footer-note { font-size: 0.88rem; color: var(--muted); line-height: 1.6; }
    @media (max-width: 980px) {
      .layout { grid-template-columns: 1fr; }
      .sky-overlay { bottom: 208px; font-size: 0.8rem; }
      .status-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="hero">
      <h1>광공해 자가진단용 회전 천구 모델</h1>
      <p class="sub">날짜·시간과 관측지 위도·경도를 넣으면 천구가 그에 맞춰 회전합니다. 천체를 직접 클릭하거나, 계절별 대표 천체 버튼을 눌러 선택할 수 있고, 간단한 질문과 연결해 대략적인 광공해 등급도 추정할 수 있게 만들었습니다.</p>
    </section>

    <div class="layout">
      <section class="panel sky-box">
        <canvas id="skyCanvas" width="960" height="600" aria-label="천구 캔버스"></canvas>
        <div class="sky-overlay">
          <span>동쪽</span>
          <span>남쪽 하늘 중심</span>
          <span>서쪽</span>
        </div>

        <div class="controls">
          <div>
            <div class="small">관측 조건</div>
            <div class="input-row">
              <label>위도 <input id="latInput" type="number" step="0.1" min="-90" max="90" value="37.6"></label>
              <label>경도 <input id="lonInput" type="number" step="0.1" min="-180" max="180" value="127.0"></label>
              <label>날짜/시간 <input id="timeInput" type="datetime-local"></label>
              <button id="nowBtn">현재 시각</button>
            </div>
          </div>
          <div>
            <div class="small">회전 제어</div>
            <div class="button-row">
              <button id="playBtn" class="active">회전: 재생 중</button>
              <button class="speedBtn" data-speed="60">×60</button>
              <button class="speedBtn active" data-speed="600">×600</button>
              <button class="speedBtn" data-speed="3600">×3600</button>
              <button id="toggleNearest" class="active">근처 천체 자동 선택: 켜짐</button>
            </div>
          </div>
          <div>
            <div class="small">계절별 대표 천체</div>
            <div class="button-row" id="seasonButtons"></div>
          </div>
          <div>
            <div class="small">보조 기능</div>
            <div class="button-row">
              <button id="showAllBtn">전체 대표 천체 보기</button>
              <button id="clearBtn">선택 해제</button>
            </div>
          </div>
        </div>
      </section>

      <aside class="panel">
        <div class="label">선택된 대표 천체</div>
        <div class="card">
          <p class="selected-name" id="objectName">아직 선택되지 않았습니다</p>
          <div class="small" id="objectDesc">천구를 누르거나 계절 버튼을 눌러 대표 천체를 고르세요. 화면에 보이지 않는 천체는 자동으로 숨겨집니다.</div>
          <div class="kv" id="objectMeta"></div>
          <div class="tip">실제 진단에서는 “지금 이 하늘에서 무엇이 보이는가”를 고르게 하면 됩니다. 예를 들어 안드로메다 은하나 데네브처럼 상대적으로 어두운 대표 천체가 보인다면 더 어두운 하늘일 가능성이 큽니다.</div>
        </div>

        <div class="card">
          <h2>현재 하늘 상태</h2>
          <div class="status-grid">
            <div class="pill"><strong>항성시 근사</strong><br><span id="lstText" class="mono">-</span></div>
            <div class="pill"><strong>보이는 대표 천체</strong><br><span id="visibleCount">-</span></div>
            <div class="pill"><strong>선택 기준점</strong><br><span id="nearestHint">자동 추정 켜짐</span></div>
          </div>
          <div class="list" id="visibleList"></div>
        </div>

        <div class="card">
          <h2>광공해 자가진단</h2>
          <div class="form-grid">
            <label>은하수가 보였나요?
              <select id="milkyWaySelect">
                <option value="0">아니요</option>
                <option value="1">희미하게</option>
                <option value="2">뚜렷하게</option>
              </select>
            </label>
            <label>하늘 배경은 어느 쪽에 가까웠나요?
              <select id="skyGlowSelect">
                <option value="3">도심처럼 밝음</option>
                <option value="2">교외처럼 약간 밝음</option>
                <option value="1">어두운 편</option>
                <option value="0">매우 어두움</option>
              </select>
            </label>
            <label>지금 선택한 천체를 실제로 맨눈으로 봤나요?
              <select id="selectedSeenSelect">
                <option value="1">예</option>
                <option value="0">아니요</option>
              </select>
            </label>
          </div>
          <div class="result-box" id="diagnosisBox">아직 진단하지 않았습니다. 천체를 하나 고른 뒤 위 항목을 선택하면 대략적인 광공해 등급을 보여 줍니다.</div>
        </div>

        <div class="footer-note">주의: 이 모델은 교육용 간이 천구입니다. 별 위치는 실제 적경·적위를 바탕으로 계산하지만, 대표 천체 수가 제한되어 있고 지형·건물·대기 상태는 반영하지 않습니다.</div>
      </aside>
    </div>
  </div>

  <script>
    const canvas = document.getElementById('skyCanvas');
    const ctx = canvas.getContext('2d');

    const latInput = document.getElementById('latInput');
    const lonInput = document.getElementById('lonInput');
    const timeInput = document.getElementById('timeInput');
    const nowBtn = document.getElementById('nowBtn');
    const playBtn = document.getElementById('playBtn');
    const speedBtns = Array.from(document.querySelectorAll('.speedBtn'));
    const seasonButtons = document.getElementById('seasonButtons');
    const objectName = document.getElementById('objectName');
    const objectDesc = document.getElementById('objectDesc');
    const objectMeta = document.getElementById('objectMeta');
    const visibleList = document.getElementById('visibleList');
    const visibleCount = document.getElementById('visibleCount');
    const lstText = document.getElementById('lstText');
    const nearestHint = document.getElementById('nearestHint');
    const toggleNearest = document.getElementById('toggleNearest');
    const showAllBtn = document.getElementById('showAllBtn');
    const clearBtn = document.getElementById('clearBtn');
    const milkyWaySelect = document.getElementById('milkyWaySelect');
    const skyGlowSelect = document.getElementById('skyGlowSelect');
    const selectedSeenSelect = document.getElementById('selectedSeenSelect');
    const diagnosisBox = document.getElementById('diagnosisBox');

    let mouseX = canvas.width / 2;
    let mouseY = canvas.height / 2;
    let autoNearest = true;
    let selectedObject = null;
    let activeSeason = 'all';
    let isPlaying = true;
    let timeSpeed = 600;
    let simDate = new Date();
    let lastFrame = performance.now();
    let currentProjected = [];

    const seasons = [
      { key: 'spring', label: '봄' },
      { key: 'summer', label: '여름' },
      { key: 'autumn', label: '가을' },
      { key: 'winter', label: '겨울' },
      { key: 'all', label: '전체' },
    ];

    const representativeObjects = [
      { id:'regulus', name:'레굴루스', season:'spring', ra:10.139, dec:11.97, mag:1.35, type:'별', hint:'봄철 사자자리의 대표 별', note:'봄철 사자자리의 중심이 되는 밝은 별입니다.' },
      { id:'spica', name:'스피카', season:'spring', ra:13.420, dec:-11.16, mag:0.98, type:'별', hint:'처녀자리의 밝은 별', note:'봄철 남쪽 하늘에서 눈에 띄는 푸른빛 별입니다.' },
      { id:'arcturus', name:'아크투루스', season:'spring', ra:14.261, dec:19.18, mag:-0.05, type:'별', hint:'목동자리의 주황빛 별', note:'봄철 곡선을 따라 찾기 쉬운 주황색 별입니다.' },

      { id:'vega', name:'직녀성(베가)', season:'summer', ra:18.615, dec:38.78, mag:0.03, type:'별', hint:'여름철 삼각형의 한 꼭짓점', note:'여름 밤하늘의 대표적인 청백색 별입니다.' },
      { id:'altair', name:'견우성(알타이르)', season:'summer', ra:19.846, dec:8.87, mag:0.77, type:'별', hint:'독수리자리의 대표 별', note:'직녀성과 함께 칠석 이야기로 잘 알려져 있습니다.' },
      { id:'deneb', name:'데네브', season:'summer', ra:20.691, dec:45.28, mag:1.25, type:'별', hint:'백조자리의 꼬리별', note:'여름철 삼각형을 이루는 대표 별입니다.' },
      { id:'antares', name:'안타레스', season:'summer', ra:16.490, dec:-26.43, mag:1.06, type:'별', hint:'전갈자리의 붉은 별', note:'붉은색이 잘 드러나는 여름철 대표 별입니다.' },

      { id:'pegasus', name:'페가수스 사각형', season:'autumn', ra:23.000, dec:20.0, mag:2.4, type:'성군 패턴', hint:'가을철 별자리 찾기의 기준 패턴', note:'가을 하늘에서 큰 사각형 모양으로 찾는 기준 패턴입니다.' },
      { id:'andromeda', name:'안드로메다 은하', season:'autumn', ra:0.712, dec:41.27, mag:3.4, type:'은하', hint:'가을철 대표 심원천체', note:'어두운 하늘에서는 맨눈으로도 희미하게 보일 수 있습니다.' },
      { id:'fomalhaut', name:'포말하우트', season:'autumn', ra:22.961, dec:-29.62, mag:1.16, type:'별', hint:'남쪽 아래쪽에 외롭게 보이는 밝은 별', note:'가을철 남쪽 낮은 하늘의 고립된 밝은 별입니다.' },

      { id:'betelgeuse', name:'베텔게우스', season:'winter', ra:5.919, dec:7.41, mag:0.5, type:'별', hint:'오리온자리의 붉은 어깨별', note:'겨울철 오리온자리를 대표하는 붉은 초거성입니다.' },
      { id:'rigel', name:'리겔', season:'winter', ra:5.243, dec:-8.20, mag:0.13, type:'별', hint:'오리온자리의 푸른 발별', note:'오리온자리 아래쪽의 푸른빛 밝은 별입니다.' },
      { id:'sirius', name:'시리우스', season:'winter', ra:6.752, dec:-16.72, mag:-1.46, type:'별', hint:'밤하늘에서 가장 밝은 항성', note:'겨울철 남동쪽 하늘에서 매우 강하게 빛나는 별입니다.' },
      { id:'capella', name:'카펠라', season:'winter', ra:5.279, dec:45.99, mag:0.08, type:'별', hint:'마차부자리의 밝은 별', note:'겨울철 높은 하늘에서 쉽게 찾을 수 있습니다.' },
    ];

    const decorativeStars = Array.from({ length: 180 }, (_, i) => ({
      az: Math.random() * 360,
      altBias: Math.random() ** 1.4,
      r: Math.random() * 1.5 + 0.2,
      a: Math.random() * 0.5 + 0.08,
      phase: i * 0.37,
    }));

    function setTimeInputFromDate(date) {
      const local = new Date(date.getTime() - date.getTimezoneOffset() * 60000);
      timeInput.value = local.toISOString().slice(0, 16);
    }

    function parseTimeInput() {
      if (!timeInput.value) return new Date();
      return new Date(timeInput.value);
    }

    function seasonLabel(key) {
      return ({ spring:'봄', summer:'여름', autumn:'가을', winter:'겨울' })[key] || '전체';
    }

    function getFilteredObjects() {
      return activeSeason === 'all'
        ? representativeObjects
        : representativeObjects.filter(obj => obj.season === activeSeason);
    }

    function createSeasonButtons() {
      seasonButtons.innerHTML = '';
      seasons.forEach(season => {
        const btn = document.createElement('button');
        btn.textContent = season.label;
        if (season.key === activeSeason) btn.classList.add('active');
        btn.addEventListener('click', () => {
          activeSeason = season.key;
          createSeasonButtons();
          draw();
        });
        seasonButtons.appendChild(btn);
      });
    }

    function julianDate(date) {
      return date.getTime() / 86400000 + 2440587.5;
    }

    function localSiderealHours(date, longitudeDeg) {
      const jd = julianDate(date);
      const d = jd - 2451545.0;
      let gmst = 18.697374558 + 24.06570982441908 * d;
      gmst = ((gmst % 24) + 24) % 24;
      let lst = gmst + longitudeDeg / 15;
      lst = ((lst % 24) + 24) % 24;
      return lst;
    }

    function equatorialToHorizontal(raHours, decDeg, lstHours, latDeg) {
      const H = ((lstHours - raHours + 12) % 24 - 12) * 15 * Math.PI / 180;
      const dec = decDeg * Math.PI / 180;
      const lat = latDeg * Math.PI / 180;

      const sinAlt = Math.sin(dec) * Math.sin(lat) + Math.cos(dec) * Math.cos(lat) * Math.cos(H);
      const alt = Math.asin(sinAlt);

      const y = -Math.sin(H) * Math.cos(dec);
      const x = Math.sin(dec) * Math.cos(lat) - Math.cos(dec) * Math.sin(lat) * Math.cos(H);
      let az = Math.atan2(y, x);
      az = (az * 180 / Math.PI + 360) % 360;
      return { altDeg: alt * 180 / Math.PI, azDeg: az };
    }

    function projectToCanvas(azDeg, altDeg) {
      const horizonY = canvas.height * 0.84;
      const domeR = canvas.height * 0.66;
      const relAz = ((azDeg - 180 + 540) % 360) - 180;
      const alt = altDeg * Math.PI / 180;
      const x = canvas.width / 2 + domeR * Math.cos(alt) * Math.sin(relAz * Math.PI / 180);
      const y = horizonY - domeR * Math.sin(alt);
      return { x, y, relAz };
    }

    function computeProjectedObjects() {
      const lat = Number(latInput.value) || 0;
      const lon = Number(lonInput.value) || 0;
      const lst = localSiderealHours(simDate, lon);
      lstText.textContent = `${lst.toFixed(2)} h`;

      currentProjected = getFilteredObjects().map(obj => {
        const horiz = equatorialToHorizontal(obj.ra, obj.dec, lst, lat);
        const p = projectToCanvas(horiz.azDeg, horiz.altDeg);
        const visible = horiz.altDeg > 0 && Math.abs(p.relAz) <= 110;
        return { ...obj, ...horiz, ...p, visible };
      }).filter(obj => obj.visible).sort((a,b) => a.mag - b.mag);

      visibleCount.textContent = `${currentProjected.length}개`;
      updateVisibleList();
      updateDiagnosis();
    }

    function updateVisibleList() {
      visibleList.innerHTML = '';
      if (!currentProjected.length) {
        const row = document.createElement('div');
        row.className = 'list-item';
        row.textContent = '현재 선택한 계절·시간 조건에서 화면 전면에 보이는 대표 천체가 없습니다.';
        visibleList.appendChild(row);
        return;
      }
      currentProjected.forEach(obj => {
        const row = document.createElement('div');
        row.className = 'list-item';
        row.innerHTML = `<span style="display:flex;align-items:center;gap:10px;"><span class="dot"></span>${obj.name}</span><span style="color:#bfd0ec;">고도 ${obj.altDeg.toFixed(0)}°</span>`;
        row.addEventListener('click', () => selectObject(obj));
        visibleList.appendChild(row);
      });
    }

    function selectObject(obj) {
      selectedObject = obj;
      objectName.textContent = obj.name;
      objectDesc.textContent = obj.note;
      objectMeta.innerHTML = `
        <div><strong>계절</strong> · ${seasonLabel(obj.season)}</div>
        <div><strong>종류</strong> · ${obj.type}</div>
        <div><strong>설명</strong> · ${obj.hint}</div>
        <div><strong>밝기(참고)</strong> · 겉보기등급 ${obj.mag}</div>
        <div><strong>현재 위치</strong> · 고도 ${obj.altDeg.toFixed(1)}°, 방위각 ${obj.azDeg.toFixed(1)}°</div>
      `;
      updateDiagnosis();
      draw();
    }

    function clearSelection() {
      selectedObject = null;
      objectName.textContent = '아직 선택되지 않았습니다';
      objectDesc.textContent = '천구를 누르거나 계절 버튼을 눌러 대표 천체를 고르세요. 화면에 보이지 않는 천체는 자동으로 숨겨집니다.';
      objectMeta.innerHTML = '';
      updateDiagnosis();
      draw();
    }

    function findNearestRepresentative(px, py) {
      let best = null;
      let bestD = Infinity;
      for (const obj of currentProjected) {
        const d = Math.hypot(px - obj.x, py - obj.y);
        if (d < bestD) {
          bestD = d;
          best = obj;
        }
      }
      return bestD <= 70 ? best : null;
    }

    function drawBackground() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const horizonY = canvas.height * 0.84;
      const domeR = canvas.height * 0.66;

      const grad = ctx.createRadialGradient(canvas.width * 0.5, canvas.height * 0.35, 12, canvas.width * 0.5, canvas.height * 0.5, canvas.width * 0.6);
      grad.addColorStop(0, '#183666');
      grad.addColorStop(0.48, '#0c1a35');
      grad.addColorStop(1, '#040912');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      const horizon = ctx.createLinearGradient(0, horizonY - 30, 0, canvas.height);
      horizon.addColorStop(0, 'rgba(40, 65, 102, 0.06)');
      horizon.addColorStop(1, 'rgba(140, 84, 44, 0.28)');
      ctx.fillStyle = horizon;
      ctx.fillRect(0, horizonY - 20, canvas.width, canvas.height - horizonY + 20);

      ctx.strokeStyle = 'rgba(255,255,255,0.08)';
      ctx.lineWidth = 1;
      for (let i = 1; i <= 5; i++) {
        const alt = i * 15;
        const y = horizonY - domeR * Math.sin(alt * Math.PI / 180);
        const rx = domeR * Math.cos(alt * Math.PI / 180);
        ctx.beginPath();
        ctx.ellipse(canvas.width / 2, y, rx, rx * 0.16, 0, 0, Math.PI * 2);
        ctx.stroke();
      }

      for (let a = -90; a <= 90; a += 30) {
        ctx.beginPath();
        for (let alt = 0; alt <= 88; alt += 2) {
          const x = canvas.width / 2 + domeR * Math.cos(alt * Math.PI / 180) * Math.sin(a * Math.PI / 180);
          const y = horizonY - domeR * Math.sin(alt * Math.PI / 180);
          if (alt === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = 'rgba(255,255,255,0.05)';
        ctx.stroke();
      }

      decorativeStars.forEach((s, idx) => {
        const az = (s.az + (simDate.getTime() / 240000) % 360) % 360;
        const alt = 5 + 82 * s.altBias;
        const p = projectToCanvas(az, alt);
        if (Math.abs(p.relAz) > 108) return;
        const twinkle = 0.72 + 0.28 * Math.sin(simDate.getTime() / 700 + s.phase + idx * 0.05);
        ctx.beginPath();
        ctx.fillStyle = `rgba(255,255,255,${s.a * twinkle})`;
        ctx.arc(p.x, p.y, s.r, 0, Math.PI * 2);
        ctx.fill();
      });

      ctx.strokeStyle = 'rgba(255,255,255,0.14)';
      ctx.beginPath();
      ctx.moveTo(canvas.width * 0.08, horizonY);
      ctx.lineTo(canvas.width * 0.92, horizonY);
      ctx.stroke();
    }

    function drawRepresentativeObjects() {
      currentProjected.forEach(obj => {
        const isSelected = selectedObject && selectedObject.id === obj.id;
        const size = Math.max(3.2, 6.2 - obj.mag * 0.8);

        ctx.beginPath();
        ctx.fillStyle = isSelected ? 'rgba(255, 209, 102, 1)' : 'rgba(210, 230, 255, 0.96)';
        ctx.shadowBlur = isSelected ? 24 : 14;
        ctx.shadowColor = isSelected ? 'rgba(255, 209, 102, 0.95)' : 'rgba(180, 220, 255, 0.65)';
        ctx.arc(obj.x, obj.y, size, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;

        if (obj.type === '은하') {
          ctx.strokeStyle = 'rgba(173, 216, 255, 0.75)';
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.ellipse(obj.x, obj.y, 18, 10, -0.35, 0, Math.PI * 2);
          ctx.stroke();
        }
        if (obj.type === '성군 패턴') {
          ctx.strokeStyle = 'rgba(255,255,255,0.35)';
          ctx.setLineDash([4,4]);
          ctx.strokeRect(obj.x - 24, obj.y - 16, 48, 32);
          ctx.setLineDash([]);
        }

        ctx.fillStyle = isSelected ? '#fff5cc' : 'rgba(255,255,255,0.9)';
        ctx.font = isSelected ? 'bold 15px sans-serif' : '13px sans-serif';
        ctx.fillText(obj.name, obj.x + 10, obj.y - 10);
      });
    }

    function drawCrosshair() {
      ctx.strokeStyle = 'rgba(255,255,255,0.16)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(mouseX - 10, mouseY); ctx.lineTo(mouseX + 10, mouseY);
      ctx.moveTo(mouseX, mouseY - 10); ctx.lineTo(mouseX, mouseY + 10);
      ctx.stroke();
    }

    function drawInfoStamp() {
      ctx.fillStyle = 'rgba(255,255,255,0.75)';
      ctx.font = '13px sans-serif';
      ctx.fillText(`위도 ${Number(latInput.value).toFixed(1)}°, 경도 ${Number(lonInput.value).toFixed(1)}°`, 18, 24);
      ctx.fillText(`${simDate.toLocaleString('ko-KR')}`, 18, 44);
    }

    function draw() {
      computeProjectedObjects();
      drawBackground();
      drawRepresentativeObjects();
      drawCrosshair();
      drawInfoStamp();
    }

    function updateDiagnosis() {
      const milkyWay = Number(milkyWaySelect.value);
      const skyGlow = Number(skyGlowSelect.value);
      const seen = Number(selectedSeenSelect.value);
      let score = 9;
      let reasons = [];

      if (selectedObject && seen) {
        if (selectedObject.mag >= 3.0) { score -= 3; reasons.push(`${selectedObject.name}처럼 비교적 어두운 천체를 봄`); }
        else if (selectedObject.mag >= 1.0) { score -= 2; reasons.push(`${selectedObject.name} 정도의 중간 밝기 천체를 봄`); }
        else { score -= 1; reasons.push(`${selectedObject.name} 같은 밝은 천체를 봄`); }
      }

      score -= milkyWay * 2;
      if (milkyWay === 1) reasons.push('은하수가 희미하게 보임');
      if (milkyWay === 2) reasons.push('은하수가 뚜렷하게 보임');
      score -= (3 - skyGlow);
      reasons.push(['하늘 배경이 매우 어두움','하늘 배경이 어두운 편','하늘 배경이 약간 밝음','하늘 배경이 매우 밝음'][skyGlow]);

      score = Math.max(1, Math.min(9, score));
      let summary = '';
      if (score <= 2) summary = '매우 어두운 시골 하늘에 가까운 편입니다.';
      else if (score <= 4) summary = '교외~준암천 수준의 비교적 좋은 하늘로 보입니다.';
      else if (score <= 6) summary = '교외~도시 외곽 정도의 중간 수준 하늘로 보입니다.';
      else summary = '도심 광공해가 강한 하늘에 가까워 보입니다.';

      diagnosisBox.innerHTML = `
        <strong>추정 보틀 등급: ${score}등급 안팎</strong><br>
        ${summary}<br>
        <span class="small">판단 근거: ${reasons.join(' · ') || '아직 조건이 충분하지 않습니다.'}</span>
      `;
    }

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouseX = (e.clientX - rect.left) * (canvas.width / rect.width);
      mouseY = (e.clientY - rect.top) * (canvas.height / rect.height);
      draw();
    });

    canvas.addEventListener('click', (e) => {
      const rect = canvas.getBoundingClientRect();
      const x = (e.clientX - rect.left) * (canvas.width / rect.width);
      const y = (e.clientY - rect.top) * (canvas.height / rect.height);

      const exact = currentProjected.find(obj => Math.hypot(obj.x - x, obj.y - y) < 18);
      if (exact) {
        selectObject(exact);
        return;
      }
      if (autoNearest) {
        const found = findNearestRepresentative(x, y);
        if (found) selectObject(found);
      }
    });

    [latInput, lonInput].forEach(el => el.addEventListener('input', draw));
    timeInput.addEventListener('input', () => {
      simDate = parseTimeInput();
      draw();
    });

    nowBtn.addEventListener('click', () => {
      simDate = new Date();
      setTimeInputFromDate(simDate);
      draw();
    });

    playBtn.addEventListener('click', () => {
      isPlaying = !isPlaying;
      playBtn.classList.toggle('active', isPlaying);
      playBtn.textContent = `회전: ${isPlaying ? '재생 중' : '일시정지'}`;
    });

    speedBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        timeSpeed = Number(btn.dataset.speed);
        speedBtns.forEach(b => b.classList.toggle('active', b === btn));
      });
    });

    toggleNearest.addEventListener('click', () => {
      autoNearest = !autoNearest;
      toggleNearest.classList.toggle('active', autoNearest);
      toggleNearest.textContent = `근처 천체 자동 선택: ${autoNearest ? '켜짐' : '꺼짐'}`;
      nearestHint.textContent = autoNearest ? '자동 추정 켜짐' : '정확 클릭만';
    });

    showAllBtn.addEventListener('click', () => {
      activeSeason = 'all';
      createSeasonButtons();
      draw();
    });

    clearBtn.addEventListener('click', clearSelection);
    milkyWaySelect.addEventListener('change', updateDiagnosis);
    skyGlowSelect.addEventListener('change', updateDiagnosis);
    selectedSeenSelect.addEventListener('change', updateDiagnosis);

    function animate(ts) {
      const dt = (ts - lastFrame) / 1000;
      lastFrame = ts;
      if (isPlaying) {
        simDate = new Date(simDate.getTime() + dt * 1000 * timeSpeed);
        setTimeInputFromDate(simDate);
      }
      draw();
      requestAnimationFrame(animate);
    }

    setTimeInputFromDate(simDate);
    createSeasonButtons();
    updateDiagnosis();
    requestAnimationFrame(animate);
  </script>
</body>
</html>
